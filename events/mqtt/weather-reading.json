{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WeatherReading",
  "type": "object",
  "required": ["station_id", "ts"],
  "properties": {
    "station_id": {"type": "string"},
    "ts": {"type": "string", "format": "date-time"},
    "temp_c": {"type": "number"},
    "humidity_pct": {"type": "number"},
    "wind_speed_mps": {"type": "number"},
    "wind_dir_deg": {"type": "number"},
    "rain_mm": {"type": "number"},
    "pressure_hpa": {"type": "number"},
    "solar_w_m2": {"type": "number"}
  }
}
