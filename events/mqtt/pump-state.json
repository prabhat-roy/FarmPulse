{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PumpState",
  "type": "object",
  "required": ["pump_id", "on", "ts"],
  "properties": {
    "pump_id": {"type": "string"},
    "on": {"type": "boolean"},
    "ts": {"type": "string", "format": "date-time"},
    "flow_lpm": {"type": "number"},
    "pressure_bar": {"type": "number"}
  }
}
