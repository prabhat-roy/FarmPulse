# ============================================================
# Project-wide local development environment.
# Copy to .env and adjust per developer.
# .env is gitignored — never commit real credentials.
# ============================================================

# ----- General -----
ENV=development
LOG_LEVEL=debug
SERVICE_DOMAIN=localhost
OFFLINE_FIRST=true

# ----- PostgreSQL + PostGIS (transactional + spatial) -----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app

# ----- TimescaleDB (sensor time-series) -----
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5433
TIMESCALE_USER=app
TIMESCALE_PASSWORD=app
TIMESCALE_DB=telemetry

# ----- InfluxDB (drone + machinery telematics) -----
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=replace-me
INFLUX_ORG=farmpulse
INFLUX_BUCKET=drone

# ----- MongoDB -----
MONGO_URI=mongodb://localhost:27017
MONGO_DB=app

# ----- Cassandra (long-term sensor archive) -----
CASSANDRA_HOSTS=localhost
CASSANDRA_KEYSPACE=farmpulse_archive

# ----- Redis -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ----- Kafka -----
KAFKA_BROKERS=localhost:9092
KAFKA_SCHEMA_REGISTRY=http://localhost:8081

# ----- NATS JetStream (cloud<->edge sync) -----
NATS_URL=nats://localhost:4222

# ----- MQTT (sensor telemetry) -----
MQTT_BROKER=tcp://localhost:1883
MQTT_BROKER_TLS=ssl://localhost:8883
MQTT_USERNAME=
MQTT_PASSWORD=

# ----- LoRaWAN (The Things Network) -----
TTN_TENANT_ID=farmpulse
TTN_APP_ID=farmpulse-soil
TTN_API_KEY=

# ----- Object storage (MinIO) -----
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=app

# ----- OpenTelemetry -----
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAMESPACE=local

# ----- Auth (Keycloak / OIDC) -----
OIDC_ISSUER_URL=http://localhost:8080/realms/app
OIDC_CLIENT_ID=app
OIDC_CLIENT_SECRET=change-me

# ----- Vault -----
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root

# ----- Feature flags (Unleash) -----
UNLEASH_URL=http://localhost:4242/api
UNLEASH_API_TOKEN=

# ----- Sentinel Hub (satellite imagery) -----
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=

# ----- Observability backends -----
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3001
LOKI_URL=http://localhost:3100
JAEGER_URL=http://localhost:16686

# ----- Edge configuration -----
EDGE_CLUSTER_ID=farm-1
EDGE_SYNC_INTERVAL_SECONDS=300
