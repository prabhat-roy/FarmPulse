{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":semanticCommits", ":dependencyDashboard"],
  "labels": ["dependencies"],
  "schedule": ["before 6am on monday"],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    },
    {
      "matchManagers": ["dockerfile"],
      "groupName": "docker base images"
    },
    {
      "matchPackagePatterns": ["^@farmpulse/"],
      "enabled": false
    },
    {
      "description": "Pin K3s edge agent to LTS",
      "matchPackageNames": ["rancher/k3s"],
      "allowedVersions": "<=v1.30.x"
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "assignees": ["@farmpulse/security"]
  }
}
